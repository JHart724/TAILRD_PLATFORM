FROM node:18-alpine

WORKDIR /app

# Install dependencies
COPY package.json package-lock.json ./
RUN npm ci --production=false

# Copy Prisma schema and generate client
COPY prisma ./prisma
RUN npx prisma generate

# Copy source
COPY src ./src
COPY tsconfig.json ./

# Run ingest script
CMD ["npx", "ts-node", "src/scripts/ingestSynthea.ts"]
