// Risk score assessments across all modules
model RiskScoreAssessment {
  id String @id @default(cuid())

  // Patient and hospital association
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Restrict)

  // Score details
  scoreType    RiskScoreType
  module       ModuleType
  totalScore   Float
  riskCategory RiskCategory

  // Score components (breakdown)
  components Json // Individual factor scores: { "age": 3, "killip": 2, ... }
  inputData  Json // Raw input values used for calculation

  // Interpretation
  interpretation String // Clinical interpretation text
  recommendation String? // Recommended clinical pathway
  mortality      Float? // Predicted mortality percentage
  eventRisk      Float? // Predicted event risk percentage

  // Clinical context
  calculatedBy    String? // User who ran the calculation
  clinicalContext String? // e.g., "Pre-PCI assessment", "Surgical evaluation"

  // Tracking
  calculatedAt DateTime  @default(now())
  validUntil   DateTime? // Score may need recalculation after this date

  createdAt DateTime @default(now())

  @@index([patientId, scoreType])
  @@index([scoreType, module])
  @@index([hospitalId, calculatedAt])
  @@map("risk_score_assessments")
}

// Intervention/procedure tracking across all modules
model InterventionTracking {
  id String @id @default(cuid())

  // Patient and hospital association
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Restrict)

  // Intervention details
  interventionName String // e.g., "DES Implantation", "TAVR", "Endovascular Revascularization"
  category         InterventionCategory
  module           ModuleType
  status           InterventionStatus

  // Coding
  cptCode           String? // CPT procedure code
  icd10Code         String? // ICD-10 procedure code
  reimbursementCode String? // HCPCS or DRG

  // Timing
  scheduledAt DateTime?
  performedAt DateTime?
  completedAt DateTime?

  // Provider
  performingProvider String?
  referringProvider  String?
  facility           String?

  // Clinical details
  indication    String?
  technique     String? // Specific technique used
  findings      Json? // Procedural findings
  complications Json? // Any complications

  // Outcome
  outcome        String? // Successful, Partially successful, Failed
  followUpPlan   String?
  nextAssessment DateTime?

  // Financial
  estimatedReimbursement Float?
  actualReimbursement    Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, module])
  @@index([module, category])
  @@index([hospitalId, performedAt])
  @@index([status, module])
  @@map("intervention_tracking")
}

// Contraindication assessment records
model ContraindicationAssessment {
  id String @id @default(cuid())

  // Patient and hospital association
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Restrict)

  // Assessment details
  module      ModuleType
  therapyName String // Drug or intervention name
  therapyType String // "medication" or "procedure"

  // Result
  level        ContraindicationLevel
  reasons      Json // Array of contraindication reasons
  alternatives Json? // Alternative therapies
  monitoring   Json? // Required monitoring if proceeding
  dosing       Json? // Recommended dosing adjustments

  // Clinical context
  assessedBy     String? // User who performed assessment
  overriddenBy   String? // If contraindication was overridden
  overrideReason String? // Clinical justification for override

  // Tracking
  assessedAt   DateTime  @default(now())
  validUntil   DateTime? // Reassessment needed after this date
  supersededBy String? // ID of newer assessment that replaces this one

  createdAt DateTime @default(now())

  @@index([patientId, module])
  @@index([therapyName, level])
  @@index([hospitalId, assessedAt])
  @@map("contraindication_assessments")
}

