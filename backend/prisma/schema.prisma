// ─── Upload Job tracking ──────────────────────────────────────────────────────
model UploadJob {
  id String @id @default(cuid())

  // Hospital association (tenant isolation)
  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Restrict)

  // Uploader
  uploadedBy String
  uploader   User @relation(fields: [uploadedBy], references: [id], onDelete: Restrict)

  // File metadata
  fileName String
  fileSize Int
  s3Key    String?
  moduleId String

  // Processing status
  status        UploadJobStatus @default(PENDING)
  startedAt     DateTime?
  completedAt   DateTime?
  errorMessage  String?
  phiDetected   Boolean         @default(false)

  // Row-level stats
  totalRows      Int @default(0)
  processedRows  Int @default(0)
  errorRows      Int @default(0)

  // Output stats
  patientsCreated Int @default(0)
  patientsUpdated Int @default(0)
  gapFlagsCreated Int @default(0)

  // Validation error details (JSON array of first N errors)
  validationErrors Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hospitalId, createdAt])
  @@index([status])
  @@map("upload_jobs")
}

enum UploadJobStatus {
  PENDING
  VALIDATING
  PROCESSING
  DETECTING_GAPS
  COMPLETE
  FAILED
  REJECTED_PHI
}

// ─── Invite Token (hospital user invitations) ────────────────────────────────
model InviteToken {
  id String @id @default(cuid())

  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Restrict)

  createdById String
  createdBy   User   @relation("InviteCreator", fields: [createdById], references: [id], onDelete: Restrict)

  email     String
  role      UserRole
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([token])
  @@index([hospitalId])
  @@map("invite_tokens")
}

model TermGapValueSet {
  gapId             String   @id
  gapName           String
  module            String
  diagnosisCodes    String[]
  exclusionCodes    String[]
  procedureCodes    String[]
  medicationCodes   String[]
  labCodes          String[]
  labThresholds     Json     @default("[]")
  deviceCodes       String[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("term_gap_valueset")
}

// ─── MFA & Session Models ────────────────────────────────────────────────────

model UserMFA {
