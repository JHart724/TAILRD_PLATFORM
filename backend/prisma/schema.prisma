// Clinical Decision Support Models

// CQL Rules for clinical logic
model CQLRule {
  id             String     @id @default(cuid())
  name           String
  version        String
  module         ModuleType
  category       String // e.g., "phenotyping", "quality_measures", "drug_titration"
  filePath       String // Path to CQL file
  isActive       Boolean    @default(true)
  lastExecuted   DateTime?
  executionCount Int        @default(0)

  // Rule metadata
  description     String?
  authoredBy      String?
  evidenceLevel   String? // A, B, C
  guidelineSource String? // ACC/AHA, ESC, etc.

  // Relationships
  cqlResults CQLResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, version])
  @@map("cql_rules")
}

// Results from CQL rule execution
model CQLResult {
  id String @id @default(cuid())

  // Patient and hospital association
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Restrict)

  // Rule association
  ruleId String
  rule   CQLRule @relation(fields: [ruleId], references: [id], onDelete: Restrict)

  // Result data
  result         Json // CQL execution result
  severity       AlertSeverity
  recommendation String?

  // Acknowledgment tracking
  acknowledgedAt DateTime?
  acknowledgedBy String?

  createdAt DateTime @default(now())

  @@index([patientId, createdAt])
  @@index([ruleId, createdAt])
  @@map("cql_results")
}

// Therapy gaps identified by CQL rules
model TherapyGap {
  id String @id @default(cuid())

  // Patient and hospital association
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Restrict)

  // Gap details
  gapType       TherapyGapType
  module        ModuleType
  medication    String? // Drug name if medication gap
  device        String? // Device type if device gap
  currentStatus String
  targetStatus  String

  // Tracking
  identifiedAt DateTime  @default(now())
  resolvedAt   DateTime?
  resolvedBy   String?

  // Additional context
  barriers        Json? // Barriers to optimal therapy
  recommendations Json? // Specific recommendations

  @@unique([id, hospitalId], name: "id_hospitalId") // AUDIT-011: enables tenant-scoped update.where { id_hospitalId }
  @@index([patientId, identifiedAt])
  @@index([module, gapType])
  @@index([hospitalId, module, resolvedAt])
  @@index([hospitalId, patientId])
  @@map("therapy_gaps")
}

// Phenotype detection and tracking
model Phenotype {
  id String @id @default(cuid())

  // Patient and hospital association
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Restrict)

  // Phenotype details
  phenotypeName PhenotypeType
  status        PhenotypeStatus
  confidence    Float // 0.0 to 1.0
  evidence      Json // Supporting evidence data

  // Tracking
  detectedAt  DateTime  @default(now())
  confirmedAt DateTime?
  confirmedBy String? // User ID who confirmed

  // Risk scoring
  riskScore   Float?
  riskFactors Json?

  @@index([patientId, phenotypeName])
  @@index([phenotypeName, status])
  @@map("phenotypes")
}

// Cross-module referrals
model CrossReferral {
  id String @id @default(cuid())

  // Patient and hospital association
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Restrict)

  // Referral details
  fromModule ModuleType
  toModule   ModuleType
  reason     String
  urgency    ReferralUrgency
  status     ReferralStatus

  // Tracking
  triggeredAt DateTime  @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?
  acceptedAt  DateTime?
  acceptedBy  String?
  completedAt DateTime?
  completedBy String?

  // Additional data
  triggerData Json? // Data that triggered the referral
  notes       String?

  @@index([patientId, status])
  @@index([fromModule, toModule])
  @@map("cross_referrals")
}

// Drug titration tracking for GDMT
model DrugTitration {
  id String @id @default(cuid())

  // Patient and hospital association
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Restrict)

  // Drug details
  drugClass        HFPillarType? // Heart failure pillars (optional for non-HF)
  generalDrugClass DrugClassType? // General drug class for all modules
  module           ModuleType     @default(HEART_FAILURE)
  drugName         String
  currentDose      Float
  currentDoseUnit  String
  targetDose       Float
  targetDoseUnit   String

  // Titration plan
  nextStepDate  DateTime?
  nextStepDose  Float?
  titrationStep Int       @default(1)

  // Barriers and monitoring
  barriers       Json? // Lab values, side effects, etc.
  monitoringPlan Json? // Required labs, vitals, etc.

  // Status tracking
  isActive     Boolean   @default(true)
  pausedReason String?
  completedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, drugClass])
  @@index([nextStepDate])
  @@map("drug_titrations")
}

// CMS Quality Measures tracking
model QualityMeasure {
  id String @id @default(cuid())

  // Hospital association
  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Restrict)

  // Measure details
  measureCode        String // CMS144, CMS145, etc.
  measureName        String
  measureDescription String?

  // Performance data
  numerator   Int // Patients meeting measure
  denominator Int // Eligible patients
  rate        Float // Performance rate (0.0 to 1.0)

  // Reporting period
  reportingPeriod String // e.g., "2024-Q1"
  periodStart     DateTime
  periodEnd       DateTime

  // Benchmark data
  nationalBenchmark Float?
  target            Float?
  previousRate      Float?

  // Additional context
  exclusions       Int? // Excluded patients
  exclusionReasons Json?

  createdAt DateTime @default(now())

  @@unique([hospitalId, measureCode, reportingPeriod])
  @@index([measureCode, periodStart])
  @@map("quality_measures")
}

// Device eligibility tracking
model DeviceEligibility {
  id String @id @default(cuid())

  // Patient and hospital association
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Restrict)

  // Device details
  deviceType  DeviceType
  deviceModel String?

  // Eligibility assessment
  eligible         Boolean
  eligibilityScore Float? // 0.0 to 1.0
  criteria         Json // Criteria met/not met
  barriers         Json? // Barriers to implantation

  // Clinical context
  indication        String?
  contraindications Json?

  // Tracking
  evaluatedAt DateTime  @default(now())
  evaluatedBy String?
  reviewedAt  DateTime?
  reviewedBy  String?

  // Outcome
  implanted      Boolean   @default(false)
  implantedAt    DateTime?
  declinedReason String?

  @@index([patientId, deviceType])
  @@index([evaluatedAt])
  @@map("device_eligibility")
}

