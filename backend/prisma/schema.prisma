// CarePlan — clinical care pathways
model CarePlan {
  id String @id @default(cuid())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Restrict)

  // Plan details
  title       String
  description String?
  status      CarePlanStatus @default(ACTIVE)
  intent      String         @default("plan") // plan, order, option
  category    String? // e.g., "hf-gdmt", "anticoagulation", "device-eval"
  moduleType  ModuleType?

  // Timing
  periodStart DateTime?
  periodEnd   DateTime?

  // Goals and activities (stored as JSON for flexibility)
  goals      Json? // Array of goal objects
  activities Json? // Array of planned activities

  // Care team
  author   String?
  careTeam Json? // Array of care team member objects

  // FHIR
  fhirCarePlanId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, status])
  @@index([hospitalId, moduleType])
  @@map("care_plans")
}

enum CarePlanStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  REVOKED
  COMPLETED
  ENTERED_IN_ERROR
}

// AuditLog — HIPAA-required PHI access tracking
model AuditLog {
  id String @id @default(cuid())

  // Nullable: failed-login events for unknown emails and other anonymous
  // events have no associated hospital. Pre-2026-04-25 the column was NOT NULL
  // and writeAuditLog wrote the literal 'unknown' which violated the FK and
  // silently dropped audit rows. See migration 20260425000000_audit_log_hospital_nullable.
  hospitalId String?
  hospital   Hospital? @relation(fields: [hospitalId], references: [id], onDelete: Restrict)

  // Who
  userId    String
  userEmail String
  userRole  String
  ipAddress String?

  // What
  action       String // "view", "create", "update", "delete", "export", "print"
  resourceType String // "Patient", "Observation", "Order", etc.
  resourceId   String?
  patientId    String? // If action involves specific patient PHI

  // Details
  description    String?
  previousValues Json? // For update actions: what changed
  newValues      Json?
  metadata       Json?

  // When
  timestamp DateTime @default(now())

  @@index([hospitalId, timestamp])
  @@index([userId, timestamp])
  @@index([patientId, timestamp])
  @@index([action, resourceType])
  @@map("audit_logs")
}

// Onboarding — per-step hospital onboarding workflow tracking
model Onboarding {
  id          String           @id @default(cuid())
  hospitalId  String
  hospital    Hospital         @relation(fields: [hospitalId], references: [id], onDelete: Restrict)
  stepName    String // BAA_EXECUTION, CREDENTIAL_DELIVERY, REDOX_SETUP, DATA_VALIDATION, etc.
  status      OnboardingStatus @default(PENDING)
  stepData    Json? // Flexible data per step (signatory info, delivery details, etc.)
  notes       String?
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([hospitalId, stepName])
  @@index([status])
  @@map("onboarding")
}

enum OnboardingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  EXPIRED
  TERMINATED
  BLOCKED
}

// InternalNote — internal team notes per hospital
model InternalNote {
  id         String   @id @default(cuid())
  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Restrict)
  noteType   String // ONBOARDING, SUPPORT, CLINICAL, BILLING, TECHNICAL
  title      String
  content    String
  priority   String   @default("MEDIUM") // LOW, MEDIUM, HIGH
  isInternal Boolean  @default(true)
  createdBy  String // userId of author
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([hospitalId, createdAt])
  @@index([noteType])
  @@map("internal_notes")
}

// ─── Breach Notification & Incident Response ─────────────────────────────────

model BreachIncident {
  id         String  @id @default(cuid())
  hospitalId String? // Null if platform-wide

  // Discovery details
  discoveredAt DateTime
  discoveredBy String // userId who identified
  incidentType BreachType
  severity     BreachSeverity

  // Scope
  description        String
  affectedRecords    Int? // Number of PHI records affected
  affectedFields     String[] // e.g., ["name", "DOB", "MRN"]
  affectedPatientIds String[] // Specific patients impacted

  // HIPAA 60-day timeline
  investigationStarted    DateTime?
  riskAssessmentCompleted DateTime?
  hhsNotifiedAt           DateTime? // HHS OCR notification
  individualsNotifiedAt   DateTime? // Affected individual notification
  mediaNotifiedAt         DateTime? // Required if >500 records

  // Investigation
  rootCause          String?
  containmentActions String?
  remediationPlan    String?

  // Status tracking
  status        BreachStatus @default(DISCOVERED)
  statusHistory Json? // Array of { status, timestamp, updatedBy, notes }

  // Documentation
  internalNotes   String?
  legalReview     Boolean   @default(false)
  legalReviewedBy String?
  legalReviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([severity])
  @@index([discoveredAt])
  @@map("breach_incidents")
}

enum BreachType {
  UNAUTHORIZED_ACCESS
  UNAUTHORIZED_DISCLOSURE
  LOSS_OF_DATA
  THEFT_OF_DATA
  IMPROPER_DISPOSAL
  HACKING_IT_INCIDENT
  OTHER
}

enum BreachSeverity {
  LOW // Minimal risk, <10 records
  MEDIUM // Moderate risk, 10-499 records
  HIGH // Significant risk, 500+ records
  CRITICAL // Imminent harm, systematic failure
}

enum BreachStatus {
  DISCOVERED
  INVESTIGATING
  CONTAINED
  RISK_ASSESSED
  HHS_NOTIFIED
  INDIVIDUALS_NOTIFIED
  REMEDIATED
  CLOSED
}

// ─── Patient Data Requests (HIPAA Access/Amendment/Deletion) ────────────────

model PatientDataRequest {
  id         String @id @default(cuid())
  hospitalId String
  patientId  String

  requestType       DataRequestType
  requestedBy       String // Name of requester
  requestorEmail    String?
  requestorRelation String? // Patient, legal guardian, authorized representative

  status DataRequestStatus @default(PENDING)
  notes  String?

  // Processing
  assignedTo    String? // userId handling the request
  processedAt   DateTime?
  responseNotes String?
  denialReason  String?

  // HIPAA timelines (30 days for access, one 30-day extension)
  dueDate          DateTime
  extensionGranted Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hospitalId, status])
  @@index([patientId])
  @@index([dueDate])
  @@map("patient_data_requests")
}

enum DataRequestType {
  ACCESS // Patient wants copy of their records
  DELETION // Patient wants records deleted
  AMENDMENT // Patient wants records corrected
  RESTRICTION // Patient wants restrictions on use
  ACCOUNTING // Patient wants accounting of disclosures
}

enum DataRequestStatus {
  PENDING
  IN_REVIEW
  APPROVED
  DENIED
  COMPLETED
  EXPIRED
}

// =============================================================================
// TERMINOLOGY MODELS — Clinical ValueSet Infrastructure
// =============================================================================

