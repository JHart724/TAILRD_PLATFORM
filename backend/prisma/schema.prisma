// Medication / MedicationStatement — patient medication lists
model Medication {
  id String @id @default(cuid())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Restrict)

  // Medication details
  medicationName String
  genericName    String?
  rxNormCode     String?
  ndc            String?
  drugClass      String? // e.g., "ACEi", "Beta-Blocker", "SGLT2i", "ARNI"

  // Dosing
  dose      String? // e.g., "25 mg"
  doseValue Float?
  doseUnit  String?
  route     String? // e.g., "oral", "IV"
  frequency String? // e.g., "BID", "daily"

  // Status
  status             MedicationStatus @default(ACTIVE)
  startDate          DateTime?
  endDate            DateTime?
  discontinuedReason String?

  // Prescriber
  prescribedBy   String?
  prescribedDate DateTime?

  // Target dose tracking (for GDMT optimization)
  targetDose      String?
  targetDoseValue Float?
  atTargetDose    Boolean @default(false)
  percentOfTarget Float? // 0.0 - 1.0

  // FHIR
  fhirMedicationId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([hospitalId, fhirMedicationId]) // Per-tenant FHIR ID uniqueness
  @@index([patientId, drugClass])
  @@index([hospitalId, status])
  @@index([rxNormCode])
  @@map("medications")
}

enum MedicationStatus {
  ACTIVE
  DISCONTINUED
  ON_HOLD
  COMPLETED
  ENTERED_IN_ERROR
}

// Condition / ProblemList — structured diagnoses with ICD-10 codes
model Condition {
  id String @id @default(cuid())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Restrict)

  // Condition details
  conditionName      String
  icd10Code          String? // e.g., "I50.22" (HFrEF)
  snomedCode         String?
  category           ConditionCategory           @default(PROBLEM_LIST)
  clinicalStatus     ConditionClinicalStatus     @default(ACTIVE)
  verificationStatus ConditionVerificationStatus @default(CONFIRMED)
  severity           String? // mild, moderate, severe

  // Timing
  onsetDate     DateTime?
  abatementDate DateTime?
  recordedDate  DateTime?

  // Clinical context
  recordedBy String?
  bodySite   String?

  // FHIR
  fhirConditionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([hospitalId, fhirConditionId]) // Per-tenant FHIR ID uniqueness
  @@index([patientId, clinicalStatus])
  @@index([hospitalId, icd10Code])
  @@index([icd10Code])
  @@map("conditions")
}

enum ConditionCategory {
  PROBLEM_LIST
  ENCOUNTER_DIAGNOSIS
  HEALTH_CONCERN
}

enum ConditionClinicalStatus {
  ACTIVE
  RECURRENCE
  RELAPSE
  INACTIVE
  REMISSION
  RESOLVED
}

enum ConditionVerificationStatus {
  UNCONFIRMED
  PROVISIONAL
  DIFFERENTIAL
  CONFIRMED
  REFUTED
