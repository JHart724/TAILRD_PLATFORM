  parentCode  String?
  createdAt   DateTime @default(now())

  @@map("term_icd10")
}

model TermRxNorm {
  rxcui       String   @id
  name        String
  termType    String
  drugClasses String[]
  brandNames  String[]
  createdAt   DateTime @default(now())

  @@map("term_rxnorm")
}

model TermLOINC {
  loincNum    String   @id
  component   String
  system      String
  scaleType   String
  className   String
  unit        String   @default("")
  createdAt   DateTime @default(now())

  @@map("term_loinc")
}

model TermCPT {
  code        String   @id
  description String
  category    String
  createdAt   DateTime @default(now())

  @@map("term_cpt")
}

model TermMSDRG {
  drgCode     String   @id
  description String
  mdc         String
