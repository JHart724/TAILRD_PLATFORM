  label      String
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  @@index([userId])
  @@map("ip_allowlist")
}



// ─── FHIR Clinical Resources (Phase 1 Audit FIX-8.1) ─────────────────────

model Procedure {
  id              String   @id @default(cuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Restrict)
  hospitalId      String
  hospital        Hospital @relation(fields: [hospitalId], references: [id])
  fhirProcedureId String?
  cptCode         String?
  snomedCode      String?
  procedureName   String?
  status          String   @default("completed")
  procedureDate   DateTime?
  performedBy     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([hospitalId, fhirProcedureId]) // Per-tenant FHIR ID uniqueness
  @@index([patientId])
  @@index([hospitalId])
  @@index([cptCode])
  @@map("procedures")
}

model DeviceImplant {
  id            String    @id @default(cuid())
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id], onDelete: Restrict)
  hospitalId    String
  hospital      Hospital  @relation(fields: [hospitalId], references: [id])
  fhirDeviceId  String?
  deviceType    String    // ICD, CRT-D, CRT-P, Pacemaker, Watchman, LVAD
  deviceStatus  String    @default("active")
  implantDate   DateTime?
  manufacturer  String?
  modelNumber   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([hospitalId, fhirDeviceId]) // Per-tenant FHIR ID uniqueness
  @@index([patientId])
  @@index([hospitalId])
  @@index([deviceType])
  @@map("device_implants")
}

model AllergyIntolerance {
  id              String   @id @default(cuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Restrict)
  hospitalId      String
  hospital        Hospital @relation(fields: [hospitalId], references: [id])
  fhirAllergyId   String?
  substanceCode   String?  // RxNorm or SNOMED code
  substanceName   String?
  allergyType     String   @default("allergy") // allergy | intolerance
  severity        String?  // mild | moderate | severe
  clinicalStatus  String   @default("active")  // active | inactive | resolved
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([hospitalId, fhirAllergyId]) // Per-tenant FHIR ID uniqueness
  @@index([patientId])
  @@index([hospitalId])
  @@index([substanceCode])
  @@map("allergy_intolerances")
}

model FailedFhirBundle {
  id            String    @id @default(cuid())
  originalPath  String
  patientFhirId String?
  hospitalId    String?
  errorMessage  String
  retryCount    Int       @default(0)
  failedAt      DateTime  @default(now())
  resolvedAt    DateTime?

  @@index([failedAt])
  @@index([resolvedAt])
  @@map("failed_fhir_bundles")
}

// CDS Hooks session tracking
model CdsHooksSession {
  id          String   @id @default(cuid())
  hookId      String   // patient-view, order-select, etc.
  fhirContext Json     // FHIR context from EHR
  patientId   String?
  hospitalId  String
  cards       Json?    // returned cards
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  hospital    Hospital @relation(fields: [hospitalId], references: [id])

  @@index([hospitalId])
  @@index([patientId])
  @@index([createdAt])
  @@map("cds_hooks_sessions")
}

// BPCI-A Episode tracking for value-based care
model BpciEpisode {
  id              String    @id @default(cuid())
  hospitalId      String
  patientId       String
  episodeType     String    // 'HF', 'AMI', 'CABG', 'HipKnee'
  anchorAdmission DateTime
  episodeEnd      DateTime?
  targetPrice     Float?
  actualSpend     Float?
  status          String    @default("ACTIVE")
  createdAt       DateTime  @default(now())

  hospital        Hospital  @relation(fields: [hospitalId], references: [id])
  patient         Patient   @relation(fields: [patientId], references: [id])

  @@index([hospitalId, status])
  @@index([patientId])
  @@map("bpci_episodes")
}

// Drug-Drug Interaction alerts
model DrugInteractionAlert {
  id              String    @id @default(cuid())
  patientId       String
  hospitalId      String
  drug1RxNorm     String
  drug1Name       String
  drug2RxNorm     String
  drug2Name       String
  interactionType String    // 'HYPERKALEMIA', 'QTC_PROLONGATION', 'BLEEDING', 'ARNI_WASHOUT'
  severity        String    // 'CRITICAL', 'HIGH', 'MEDIUM'
  recommendation  String
  status          String    @default("ACTIVE")
  acknowledgedBy  String?
  acknowledgedAt  DateTime?
  createdAt       DateTime  @default(now())

  patient         Patient   @relation(fields: [patientId], references: [id])
  hospital        Hospital  @relation(fields: [hospitalId], references: [id])

  @@index([patientId, status])
  @@index([hospitalId, severity])
  @@map("drug_interaction_alerts")
}
